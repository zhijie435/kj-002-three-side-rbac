{
    "name": "shearerline/extension",
    "description": "Shearerline - 剪切线管理扩展包，适用于电商订单库存后台系统",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shearerline Team",
            "email": "dev@shearerline.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Shearerline\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shearerline\\ShearerlineServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
